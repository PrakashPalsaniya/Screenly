# Docker Compose environment for Screenly
COMPOSE_PROJECT_NAME=screenly

# Published ports
BACKEND_PORT=5002
FRONTEND_PORT=5173
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Backend runtime
NODE_ENV=production
PORT=5002
MONGO_CONNECTION_STRING=mongodb://localhost:27017/screenly
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379
RABBITMQ_URL=amqp://rabbitmq
FRONTEND_URL=http://localhost:5173
HASH_SECRET=replace-with-a-strong-random-secret
ACCESS_TOKEN_SECRET=replace-with-a-strong-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRES_IN=5m
REFRESH_TOKEN_EXPIRES_IN=7d
ACCESS_TOKEN_COOKIE_MAX_AGE_MS=300000
REFRESH_TOKEN_COOKIE_MAX_AGE_MS=604800000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
EMAIL_USERNAME=your-smtp-email@example.com
EMAIL_PASSWORD=your-smtp-app-password
RAZORPAY_API_KEY=your-razorpay-key
RAZORPAY_SECRET_KEY=your-razorpay-secret
TMDB_API_READ_ACCESS_TOKEN=your-tmdb-read-access-token
TMDB_API_KEY=your-tmdb-api-key
TMDB_REGION=IN
TMDB_LANGUAGE=en-IN
CLOUDINARY_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
SCREENLY_LOGO_URL=

# AWS S3 Configuration - Poster Storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET=your-s3-bucket-name

# CloudFront Distribution (for serving S3 images)
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
VITE_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Frontend environment variables
VITE_BACKEND_URL=http://localhost:5002/api/v1
VITE_RAZORPAY_API_KEY=your-razorpay-key
